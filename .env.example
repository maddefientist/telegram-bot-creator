# Telegram Bot Creator - Environment Configuration
# Copy this to .env and fill in your values

# ===========================================
# REQUIRED - Application will not start without these
# ===========================================

# OpenRouter API key for AI bot generation
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxx

# JWT secret for authentication (min 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# CSRF protection secret
# Generate with: openssl rand -hex 32
CSRF_SECRET=your-csrf-secret-key-min-32-chars

# Encryption key for Telegram tokens (Fernet key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key

# Database connection string
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/botcreator

# Redis connection string
REDIS_URL=redis://redis:6379/0

# Solana RPC endpoint
# Public: https://api.mainnet-beta.solana.com
# Devnet: https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# Your Solana treasury wallet address for receiving payments
SOLANA_TREASURY_ADDRESS=YourTreasuryWalletAddressHere

# Shared secret for runner-API authentication
# Generate with: openssl rand -hex 32
RUNNER_SHARED_SECRET=your-runner-shared-secret

# ===========================================
# OPTIONAL - Sensible defaults provided
# ===========================================

# OpenRouter model to use for generation
# Options: anthropic/claude-3.5-sonnet, openai/gpt-4o, etc.
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Application base URL (used for CORS, webhooks)
APP_BASE_URL=http://localhost:3000

# API base URL
API_BASE_URL=http://localhost:8000

# Pricing configuration (in SOL)
PRICING_MIN_SOL=0.01
PRICING_MAX_SOL=10.0
DEFAULT_PRICE_SOL=0.1

# Grace period in days after subscription expires
GRACE_DAYS=3

# Rate limiting
AI_GENERATION_RATE_LIMIT=10  # per hour per user
API_RATE_LIMIT=100  # per minute per IP

# Bot container resource limits
BOT_MEMORY_LIMIT=256m
BOT_CPU_LIMIT=0.5

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ===========================================
# PRODUCTION OVERRIDES
# ===========================================

# Domain for production (enables TLS via Caddy)
# APP_DOMAIN=yourdomain.com

# Use production database credentials
# DATABASE_URL=postgresql+asyncpg://produser:prodpass@db:5432/botcreator

# Solana mainnet RPC (use dedicated provider for production)
# SOLANA_RPC_URL=https://your-rpc-provider.com

# ===========================================
# DATABASE (for docker-compose)
# ===========================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=botcreator

# ===========================================
# INTERNAL (usually don't change)
# ===========================================

# Docker network for bot containers
DOCKER_NETWORK=botcreator_default

# Runner image name
RUNNER_IMAGE=botcreator-runner:latest
