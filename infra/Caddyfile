# Caddyfile for Telegram Bot Creator
# For local development, Caddy runs on HTTP
# For production with a domain, Caddy auto-provisions TLS

{
	# Global options
	admin off
	# Uncomment for debug logging
	# log {
	# 	level DEBUG
	# }
}

# Development configuration (no domain)
:80 {
	# Frontend
	handle {
		reverse_proxy web:3000
	}

	# API routes
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy api:8000
	}

	# API docs (development only)
	handle /docs* {
		reverse_proxy api:8000
	}

	handle /redoc* {
		reverse_proxy api:8000
	}

	handle /openapi.json {
		reverse_proxy api:8000
	}

	# Health endpoints
	handle /health {
		reverse_proxy api:8000
	}

	# Logging
	log {
		output stdout
		format console
	}
}

# Production configuration (uncomment and set your domain)
